# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Configurations for Email Checkout Delivery
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="sender@example.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
FROM_NAME="EditorsMega Team"

# PayPal Smart Payment Buttons Client Credentials
# 1. Go to https://developer.paypal.com and sign in with your business account.
# 2. Under "Apps & Credentials", create an App or use an existing one.
# 3. Copy your live "Client ID" or "Sandbox Client ID".
# 4. Paste it here to replace the fallback "sb" sandbox key automatically.
VITE_PAYPAL_CLIENT_ID="sb"

# Razorpay Checkout Gateway Configuration
# 1. Go to https://dashboard.razorpay.com and log in to your account.
# 2. Go to Settings > API Keys and generate your Key ID (test or live).
# 3. Paste the Key ID here (starts with rzp_test_ or rzp_live_).
# 4. Set VITE_RAZORPAY_CURRENCY to USD or INR depending on your Razorpay account's enabled billing currencies.
VITE_RAZORPAY_KEY_ID="rzp_test_zSgJb2pAbA9G8H"
VITE_RAZORPAY_CURRENCY="INR"

# Razorpay Backend Secrets (Keep secure, do not prefix with VITE_)
RAZORPAY_KEY_ID="rzp_test_T1yeBnG2q80O9c"
RAZORPAY_KEY_SECRET="l5isCZjFqL56sVNMchB7Bl3I"

